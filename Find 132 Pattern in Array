class Solution:
    def has132Pattern(self, arr):
        # code here 
        stack = []
        third = float('-inf')  # This will act as arr[k]
        
        # Traverse from right to left
        for i in range(len(arr) - 1, -1, -1):
            
            # If we find a number smaller than 'third'
            if arr[i] < third:
                return True
            
            # Update 'third'
            while stack and stack[-1] < arr[i]:
                third = stack.pop()
            
            stack.append(arr[i])
        
        return False
        
