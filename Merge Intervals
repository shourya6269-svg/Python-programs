class Solution:
    def merge(self, intervals):
        intervals.sort()  
        result = []
        for interval in intervals:
            if not result:
                result.append(interval)
            else:
                last = result[-1]
                if last[1] >= interval[0]:
                    last[1] = max(last[1], interval[1])
                else:
                    result.append(interval)
        return result


        
