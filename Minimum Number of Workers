class Solution:
    def minMen(self, arr):
        n = len(arr)
        intervals = []
        
        # Step 1: Create intervals
        for i in range(n):
            if arr[i] != -1:
                start = max(0, i - arr[i])
                end = min(n - 1, i + arr[i])
                intervals.append((start, end))
        
        # Step 2: Sort intervals
        intervals.sort()
        
        count = 0
        i = 0
        covered = 0
        
        # Step 3: Greedy covering
        while covered < n:
            farthest = covered
            
            while i < len(intervals) and intervals[i][0] <= covered:
                farthest = max(farthest, intervals[i][1] + 1)
                i += 1
            
            # If we cannot extend coverage
            if farthest == covered:
                return -1
            
            covered = farthest
            count += 1
        
        return count 
        
