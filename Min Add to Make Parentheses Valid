class Solution:
    def minParentheses(self, s):
        open_needed = 0
        additions = 0
        
        for ch in s:
            if ch == '(':
                open_needed += 1
            else:
                if open_needed > 0:
                    open_needed -= 1
                else:
                    additions += 1
        
        return additions + open_needed
